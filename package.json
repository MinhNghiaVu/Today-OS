    "check:all": "bun run check && bun run check:dead",
    "test": "bun test"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "4",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "knip": "^6.14.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "type": "module",
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@neondatabase/serverless": "^1.1.0",
    "lucide-svelte": "^1.0.1",
    "marked": "^18.0.2"
  }
}
